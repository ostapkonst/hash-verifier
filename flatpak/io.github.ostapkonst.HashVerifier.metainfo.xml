<?xml version="1.0" encoding="UTF-8"?>
<component>
  <id>io.github.ostapkonst.HashVerifier</id>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  <name>HashVerifier</name>
  <summary>Cross-platform checksum generation and verification tool</summary>
  <description>
    <p>
      Cross-platform checksum generation and verification tool with CLI and GTK3 GUI.
      Features recursive directory hashing, file verification, real-time progress tracking,
      and support for symbolic links.
    </p>
    <p>
      Supports 11 hash algorithms: CRC32, MD4, MD5, SHA1, SHA256, SHA384, SHA512,
      SHA3-256, SHA3-384, SHA3-512, and BLAKE3.
    </p>
  </description>
  <launchable type="desktop-id">io.github.ostapkonst.HashVerifier.desktop</launchable>
  <screenshots>
    <screenshot type="default">
      <caption>Generate tab</caption>
      <image>https://raw.githubusercontent.com/ostapkonst/hash-verifier/master/docs/screenshots/generate-tab.png</image>
    </screenshot>
    <screenshot>
      <caption>Verify tab</caption>
      <image>https://raw.githubusercontent.com/ostapkonst/hash-verifier/master/docs/screenshots/verify-tab.png</image>
    </screenshot>
    <screenshot>
      <caption>Checksum result</caption>
      <image>https://raw.githubusercontent.com/ostapkonst/hash-verifier/master/docs/screenshots/checksum-result.png</image>
    </screenshot>
  </screenshots>
  <branding>
